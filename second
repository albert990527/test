;font-size:11px;letter-spacing:2px}\n  .theme-btn{border:1px solid var(--line-strong);background:var(--surface);color:var(--ink);width:38px;height:38px;border-radius:10px;font-size:16px;box-shadow:var(--sh)}\n\n  .card{background:var(--surface);border:1px solid var(--line);border-radius:16px;box-shadow:var(--sh);overflow:hidden;margin-bottom:16px}\n  .card-b{padding:22px}\n  .login h1{margin:0 0 4px;font-size:20px}.login p{margin:0 0 20px;color:var(--ink-soft);font-size:13px}\n  label.fl{display:block;font-size:12px;color:var(--ink-soft);margin:0 0 6px;font-weight:600;letter-spacing:.3px}\n  .fld{width:100%;border:1px solid var(--line-strong);border-radius:10px;padding:11px 13px;background:var(--surface);margin-bottom:14px}\n  .fld:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(176,129,43,.16)}\n  .go{width:100%;border:0;background:var(--side-bg);color:#fff;padding:12px;border-radius:10px;font-size:15px;font-weight:600;letter-spacing:1px}\n  .go:hover{background:#0f1830}\n  .err{color:var(--bad);font-size:13px;margin-top:4px;min-height:18px}\n  .note{color:var(--ink-faint);font-size:11.5px;line-height:1.6;margin-top:16px;text-align:center}\n\n  .stu-head{background:var(--side-bg);color:#fff;padding:20px 22px}\n  .stu-head .nm{font-size:24px;font-weight:800;letter-spacing:1px}\n  .stu-head .meta{color:#AEB8CE;font-family:var(--mono);font-size:12.5px;margin-top:4px}\n  .ctabs{display:flex;gap:6px;flex-wrap:wrap;padding:12px 22px;border-bottom:1px solid var(--line);background:var(--surface-2)}\n  .ctab{border:1px solid var(--line);background:var(--surface);color:var(--ink-soft);padding:6px 13px;border-radius:20px;font-size:12.5px;font-weight:600}\n  .ctab.on{background:var(--side-bg);color:#fff;border-color:var(--side-bg)}\n  .ctab .dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:6px;vertical-align:middle}\n\n  .final-box{display:flex;align-items:center;gap:16px;padding:20px 22px;border-bottom:1px solid var(--line)}\n  .final-num{font-family:var(--mono);font-size:46px;font-weight:800;line-height:1}\n  .final-box .lab{font-size:12px;color:var(--ink-soft);letter-spacing:.5px}\n  .badge{font-size:12px;font-weight:700;padding:3px 11px;border-radius:20px;display:inline-block}\n  .badge.ok{background:#E4F2EA;color:var(--ok)}.badge.warn{background:#FBF0DD;color:#9A6205}.badge.bad{background:#FBE6E8;color:var(--bad)}\n  .sec{padding:16px 22px;border-bottom:1px solid var(--line)}.sec:last-of-type{border-bottom:0}\n  .sec h3{margin:0 0 12px;font-size:13px;color:var(--ink-soft);letter-spacing:1px;font-weight:700}\n  .kv{display:flex;justify-content:space-between;align-items:center;padding:7px 0}\n  .kv .k{color:var(--ink-soft)}.kv .v{font-family:var(--mono);font-weight:600}\n  table{width:100%;border-collapse:collapse;font-size:13.5px}\n  th,td{padding:8px 6px;text-align:left;border-bottom:1px solid var(--line)}\n  th{font-size:11.5px;color:var(--ink-faint);font-weight:600;letter-spacing:.4px}\n  td.c,th.c{text-align:center}td.r,th.r{text-align:right}\n  .tag{display:inline-block;font-size:11px;padding:1px 7px;border-radius:20px;border:1px solid var(--line);color:var(--ink-soft);background:var(--surface-2)}\n  .tag.hw{color:var(--att);border-color:#B7D0C9}.tag.ex{color:var(--grd);border-color:#B9C6DE}\n  .miss{color:var(--bad);font-size:12px}\n  .bar{display:flex;height:12px;border-radius:6px;overflow:hidden;background:var(--surface-2);border:1px solid var(--line);margin-top:6px}\n  .bar i{display:block;height:100%}.bar .a{background:var(--att)}.bar .g{background:var(--grd)}\n  .chips{display:flex;flex-wrap:wrap;gap:6px}\n  .chip{font-size:12px;font-weight:600;padding:3px 10px;border-radius:20px;background:#FBF0DD;color:#9A6205}\n  .allgood{color:var(--ok);font-size:13px}\n  .bonus-row{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:1px dashed var(--line)}\n  .btn-back{border:1px solid var(--line-strong);background:var(--surface);color:var(--ink);padding:9px 16px;border-radius:10px;font-size:13px;margin:18px 22px}\n  .btn-back:hover{background:var(--surface-2)}\n  .sum{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--line)}\n  .sum:last-child{border-bottom:0}\n  .sum .cn{font-weight:600}.sum .cs{font-family:var(--mono);font-weight:700;font-size:16px}\n  .fade{animation:f .35s ease}@keyframes f{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}\n</style>\n\n<div class=\"wrap\">\n  <div class=\"top\">\n    <div class=\"brand\"><span class=\"seal\">TA</span><div><b id=\"ttl\">\u5b78\u751f\u6210\u7e3e\u67e5\u8a62</b><small>STUDENT PORTAL</small></div></div>\n    <button class=\"theme-btn\" id=\"themeBtn\" title=\"\u6df1\u8272/\u6dfa\u8272\">\u263e</button>\n  </div>\n  <div id=\"app\"></div>\n  <p class=\"note\" id=\"footNote\"></p>\n</div>\n\n<script>\n\"use strict\";\n/* \u52a9\u6559\u7aef\u6703\u628a\u300c\u5168\u90e8\u73ed\u7d1a\u300d\u8cc7\u6599\u4ee5 base64 \u586b\u5165\u4e0b\u65b9\u4f54\u4f4d\u7b26 */\nconst RAW=\"@@PORTAL_DATA@@\";\n\nfunction b64decodeUTF8(s){ return decodeURIComponent(escape(atob(s))); }\nlet D=null;\ntry{ D = (RAW && RAW.charAt(0)!==\"@\") ? JSON.parse(b64decodeUTF8(RAW)) : null; }catch(e){ D=null; }\n\nfunction clamp(n,a,b){ return Math.max(a,Math.min(b,n)); }\nfunction esc(s){ return String(s==null?\"\":s).replace(/[&<>\"']/g,c=>({\"&\":\"&amp;\",\"<\":\"&lt;\",\">\":\"&gt;\",'\"':\"&quot;\",\"'\":\"&#39;\"}[c])); }\nfunction fmt(n,d=1){ return (n==null||isNaN(n))?\"\u2014\":Number(n).toFixed(d); }\n\n/* \u8a08\u7b97(\u8207\u52a9\u6559\u7aef\u540c\u4e00\u5957\u898f\u5247) */\nfunction attScore(cls,s){ const v=cls.attDirect[s.id]; return (v==null||v===\"\"||isNaN(v))?null:clamp(+v,0,100); }\nfunction gScore(cls,s){ const items=cls.gradeItems; if(!items.length) return null;\n  const g=cls.grades[s.id]||{}, zero=cls.settings.missingAsZero; let sum=0,w=0,any=false;\n  items.forEach(i=>{ const v=g[i.id],ww=+i.weight||0,mx=+i.max||100,has=(v!=null&&v!==\"\"&&!isNaN(v));\n    if(has){ sum+=(v/mx*100)*ww; w+=ww; any=true; } else if(zero){ w+=ww; } });\n  if(!any&&!zero) return null; return w?sum/w:(zero?0:null); }\nfunction bonusOf(cls,s){ return (cls.perfLog||[]).filter(e=>e.studentId===s.id).reduce((a,e)=>a+(+e.bonus||0),0); }\nfunction finalOf(cls,s){ const w=cls.settings.weights,a=attScore(cls,s)??0,g=gScore(cls,s)??0,b=bonusOf(cls,s);\n  return clamp(a*w.attendance/100+g*w.grade/100+b,0,100); }\nfunction statusBadge(cls,f){ const p=cls.settings.passLine;\n  if(f>=Math.max(p+20,80)) return `<span class=\"badge ok\">\u512a\u826f</span>`;\n  if(f>=p) return `<span class=\"badge ok\">\u53ca\u683c</span>`;\n  if(f>=p-10) return `<span class=\"badge warn\">\u908a\u7de3</span>`;\n  return `<span class=\"badge bad\">\u672a\u9054\u53ca\u683c</span>`; }\nfunction statusColor(cls,f){ const p=cls.settings.passLine; return f>=p?'var(--ok)':(f>=p-10?'var(--warn)':'var(--bad)'); }\nfunction reminders(cls,s){ const out=[]; const a=attScore(cls,s);\n  if(a!=null&&a<60) out.push(\"\u9ede\u540d\u504f\u4f4e,\u8a18\u5f97\u51fa\u5e2d\");\n  const g=cls.grades[s.id]||{}; const miss=i=>{ const v=g[i.id]; return v==null||v===\"\"||isNaN(v); };\n  const ex=cls.gradeItems.filter(i=>i.category===\"\u8003\u8a66\"&&miss(i)).length;\n  const hw=cls.gradeItems.filter(i=>i.category===\"\u4f5c\u696d\"&&miss(i)).length;\n  if(ex) out.push(\"\u6709 \"+ex+\" \u9805\u8003\u8a66\u672a\u7e73/\u7f3a\u8003\");\n  if(hw) out.push(\"\u6709 \"+hw+\" \u9805\u4f5c\u696d\u672a\u4ea4\");\n  const gs=gScore(cls,s); if(gs!=null&&gs<cls.settings.passLine) out.push(\"\u6210\u7e3e\u504f\u4f4e,\u53ef\u627e\u52a9\u6559\u8a0e\u8ad6\");\n  return out; }\n\n/* \u8de8\u5168\u90e8\u73ed\u7d1a\u5c0b\u627e\u6b64\u5b78\u751f */\nfunction findAll(acct,name){\n  const hits=[];\n  (D.classes||[]).forEach(cls=>{\n    const s=cls.students.find(x=>String(x.sid).trim()===acct && String(x.name).trim()===name);\n    if(s) hits.push({cls,s});\n  });\n  return hits;\n}\n\nconst app=document.getElementById(\"app\");\nlet HITS=null, curIdx=0;\n\nfunction loginView(){\n  if(!D || !(D.classes||[]).length){\n    app.innerHTML=`<div class=\"card\"><div class=\"card-b login\"><h1>\u5c1a\u672a\u8f09\u5165\u8cc7\u6599</h1>\n      <p>\u9019\u662f\u7a7a\u767d\u7684\u67e5\u8a62\u9801\u6a21\u677f\u3002\u8acb\u7531\u52a9\u6559\u7aef\u300c\u7522\u751f\u5b78\u751f\u67e5\u8a62\u9801\u300d\u5e36\u5165\u73ed\u7d1a\u8cc7\u6599\u5f8c\u518d\u5206\u4eab\u3002</p></div></div>`; return; }\n  const nCls=D.classes.length, nStu=D.classes.reduce((a,c)=>a+c.students.length,0);\n  document.getElementById(\"ttl\").textContent=\"\u5b78\u751f\u6210\u7e3e\u67e5\u8a62\";\n  document.getElementById(\"footNote\").textContent=\"\u6210\u7e3e\u4ee5\u52a9\u6559\u6700\u5f8c\u66f4\u65b0\u70ba\u6e96;\u50c5\u4f9b\u672c\u4eba\u67e5\u8a62\u3002\";\n  app.innerHTML=`<div class=\"card fade\"><div class=\"card-b login\">\n    <h1>\u67e5\u8a62\u6211\u7684\u6210\u7e3e</h1><p>\u672c\u67e5\u8a62\u6db5\u84cb ${nCls} \u500b\u73ed\u7d1a \u00b7 \u5171 ${nStu} \u7b46\u4fee\u8ab2\u7d00\u9304</p>\n    <label class=\"fl\">\u5b78\u865f / \u5e33\u865f</label><input class=\"fld\" id=\"acct\" placeholder=\"\u4f8b\u5982:409650586\" autocomplete=\"off\">\n    <label class=\"fl\">\u59d3\u540d(\u9a57\u8b49\u7528)</label><input class=\"fld\" id=\"nm\" placeholder=\"\u8f38\u5165\u4f60\u7684\u59d3\u540d\" autocomplete=\"off\">\n    <button class=\"go\" id=\"qbtn\">\u67e5 \u8a62</button>\n    <div class=\"err\" id=\"err\"></div>\n    <p class=\"note\">\u70ba\u4fdd\u8b77\u96b1\u79c1,\u9700\u5e33\u865f\u8207\u59d3\u540d\u76f8\u7b26\u624d\u80fd\u67e5\u770b\u3002<br>\u82e5\u4f60\u4fee\u4e86\u591a\u9580\u8ab2,\u6703\u4e00\u6b21\u5217\u51fa\u5168\u90e8\u3002</p>\n  </div></div>`;\n  const acct=document.getElementById(\"acct\"), nm=document.getElementById(\"nm\");\n  const go=()=>{ const a=(acct.value||\"\").trim(), n=(nm.value||\"\").trim();\n    if(!a||!n){ document.getElementById(\"err\").textContent=\"\u8acb\u8f38\u5165\u5e33\u865f\u8207\u59d3\u540d\"; return; }\n    const hits=findAll(a,n);\n    if(!hits.length){ document.getElementById(\"err\").textContent=\"\u67e5\u7121\u6b64\u4eba,\u6216\u59d3\u540d\u8207\u5e33\u865f\u4e0d\u7b26\"; return; }\n    HITS=hits; curIdx=0; resultView(); };\n  document.getElementById(\"qbtn\").onclick=go;\n  [acct,nm].forEach(el=>el.onkeydown=e=>{ if(e.key===\"Enter\") go(); });\n  acct.focus();\n}\n\nfunction resultView(){\n  const {cls,s}=HITS[curIdx];\n  const w=cls.settings.weights, a=attScore(cls,s), g=gScore(cls,s), b=bonusOf(cls,s), f=finalOf(cls,s);\n  const ca=(a??0)*w.attendance/100, cg=(g??0)*w.grade/100, tot=Math.max(1,ca+cg);\n  const gmap=cls.grades[s.id]||{};\n  const rows=cls.gradeItems.map(i=>{ const raw=gmap[i.id]; const has=(raw!=null&&raw!==\"\"&&!isNaN(raw)); const mx=+i.max||100;\n    return `<tr><td><span class=\"tag ${i.category==='\u4f5c\u696d'?'hw':'ex'}\">${esc(i.category)}</span></td>\n      <td>${esc(i.name)}</td>\n      <td class=\"c\">${has?`<span class=\"num\">${raw} / ${mx}</span>`:'<span class=\"miss\">\u672a\u7e73</span>'}</td>\n      <td class=\"r num\">${has?fmt(raw/mx*100,0)+'%':'\u2014'}</td></tr>`; }).join(\"\");\n  const rem=reminders(cls,s);\n  const bonusList=(cls.perfLog||[]).filter(e=>e.studentId===s.id);\n\n  // \u591a\u73ed\u6642\u7684\u5207\u63db\u5217 + \u5168\u90e8\u8ab2\u7a0b\u7e3d\u89bd\n  const tabs = HITS.length>1 ? `<div class=\"ctabs\">${HITS.map((h,i)=>{\n      const ff=finalOf(h.cls,h.s);\n      return `<button class=\"ctab ${i===curIdx?'on':''}\" data-ci=\"${i}\"><span class=\"dot\" style=\"background:${statusColor(h.cls,ff)}\"></span>${esc(h.cls.name)}</button>`;\n    }).join(\"\")}</div>` : \"\";\n  const overview = HITS.length>1 ? `<div class=\"card fade\"><div class=\"sec\" style=\"border-bottom:0\">\n      <h3>\u6211\u7684\u5168\u90e8\u8ab2\u7a0b(${HITS.length} \u9580)</h3>\n      ${HITS.map((h,i)=>{ const ff=finalOf(h.cls,h.s);\n        return `<div class=\"sum\"><span class=\"cn\">${esc(h.cls.name)}</span>\n          <span><span class=\"cs\" style=\"color:${statusColor(h.cls,ff)}\">${fmt(ff)}</span> &nbsp;${statusBadge(h.cls,ff)}</span></div>`; }).join(\"\")}\n    </div></div>` : \"\";\n\n  app.innerHTML=`${overview}<div class=\"card fade\">\n    <div class=\"stu-head\"><div class=\"nm\">${esc(s.name)}</div>\n      <div class=\"meta\">${esc(s.sid)}${s.dept?' \u00b7 '+esc(s.dept):''}${s.group?' \u00b7 '+esc(s.group)+' \u73ed':''}</div></div>\n    ${tabs}\n    <div class=\"sec\" style=\"padding-top:14px;padding-bottom:0\"><h3>${esc(cls.name)}${cls.term?' \u00b7 '+esc(cls.term):''}</h3></div>\n    <div class=\"final-box\"><div><div class=\"lab\">\u6df7\u5408\u6210\u7e3e</div>\n      <div class=\"final-num\" style=\"color:${f>=cls.settings.passLine?'var(--ink)':'var(--bad)'}\">${fmt(f)}</div></div>\n      <div style=\"margin-left:auto;text-align:right\">${statusBadge(cls,f)}<div class=\"lab\" style=\"margin-top:6px\">\u53ca\u683c\u7dda ${cls.settings.passLine}</div></div></div>\n\n    <div class=\"sec\"><h3>\u6210\u7e3e\u7d44\u6210</h3>\n      <div class=\"kv\"><span class=\"k\">\u9ede\u540d\u6210\u7e3e</span><span class=\"v\" style=\"color:${a!=null&&a<60?'var(--bad)':''}\">${fmt(a,1)}<span style=\"color:var(--ink-faint)\"> \u00d7${w.attendance}%</span></span></div>\n      <div class=\"kv\"><span class=\"k\">\u52a0\u6b0a\u6210\u7e3e(\u5404\u9805)</span><span class=\"v\">${fmt(g,1)}<span style=\"color:var(--ink-faint)\"> \u00d7${w.grade}%</span></span></div>\n      ${b?`<div class=\"kv\"><span class=\"k\">\u8ab2\u5802\u52a0\u5206</span><span class=\"v\" style=\"color:var(--gold)\">+${fmt(b,1)}</span></div>`:''}\n      <div class=\"bar\"><i class=\"a\" style=\"width:${ca/tot*100}%\"></i><i class=\"g\" style=\"width:${cg/tot*100}%\"></i></div>\n      <div style=\"display:flex;justify-content:space-between;font-size:11px;color:var(--ink-faint);margin-top:5px\"><span>\u25a0 \u9ede\u540d\u8ca2\u737b ${fmt(ca)}</span><span>\u6210\u7e3e\u8ca2\u737b ${fmt(cg)} \u25a0</span></div>\n    </div>\n\n    <div class=\"sec\"><h3>\u5404\u9805\u6210\u7e3e\u660e\u7d30</h3>\n      <table><thead><tr><th>\u5206\u985e</th><th>\u9805\u76ee</th><th class=\"c\">\u6211\u7684\u5f97\u5206</th><th class=\"r\">\u63db\u7b97</th></tr></thead>\n      <tbody>${rows||'<tr><td colspan=\"4\" style=\"color:var(--ink-faint)\">\u5c1a\u7121\u6210\u7e3e\u9805\u76ee</td></tr>'}</tbody></table>\n    </div>\n\n    ${bonusList.length?`<div class=\"sec\"><h3>\u8ab2\u5802\u52a0\u5206\u7d00\u9304</h3>\n      ${bonusList.map(e=>`<div class=\"bonus-row\"><span>${esc(e.session||'\u2014')}${e.note?' \u00b7 '+esc(e.note):''}</span><span class=\"num\" style=\"color:var(--gold)\">+${esc(e.bonus)}</span></div>`).join(\"\")}</div>`:''}\n\n    <div class=\"sec\"><h3>\u5b78\u7fd2\u63d0\u9192</h3>\n      ${rem.length?`<div class=\"chips\">${rem.map(t=>`<span class=\"chip\">${esc(t)}</span>`).join(\"\")}</div>`:'<div class=\"allgood\">\u76ee\u524d\u72c0\u614b\u826f\u597d,\u7e7c\u7e8c\u4fdd\u6301 \ud83d\udc4d</div>'}\n    </div>\n    <button class=\"btn-back\" id=\"back\">\u2190 \u8fd4\u56de\u67e5\u8a62</button>\n  </div>`;\n  document.querySelectorAll(\"[data-ci]\").forEach(b=>b.onclick=()=>{ curIdx=+b.dataset.ci; resultView(); });\n  document.getElementById(\"back\").onclick=loginView;\n  window.scrollTo({top:0,behavior:\"smooth\"});\n}\n\n(function(){ const b=document.getElementById(\"themeBtn\");\n  const set=t=>{ document.body.classList.toggle(\"dark\",t===\"dark\"); b.textContent=t===\"dark\"?\"\u2600\":\"\u263e\"; try{localStorage.setItem(\"portal_theme\",t);}catch(e){} };\n  let t=\"light\"; try{ t=localStorage.getItem(\"portal_theme\")||\"light\"; }catch(e){}\n  set(t); b.onclick=()=>set(document.body.classList.contains(\"dark\")?\"light\":\"dark\");\n})();\nloginView();\n<\/script>\n";

