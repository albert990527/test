  const n=clamp(parseInt(el&&el.value)||2,1,Math.max(1,cls.students.length)); groupN=n;
  const sh=cls.students.slice(); for(let i=sh.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); const t=sh[i]; sh[i]=sh[j]; sh[j]=t; }
