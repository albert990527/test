        · <b>點名欄可有可無</b>:沒有點名欄時不會動到既有點名成績<br>
        · 標記「未繳」視為未繳交(空白)
      </p>
    </div></div>
  ${p?diffCard(p):""}`;
}
function diffCard(p){
  const plan=p.plan;
  const grp=(title,n,color,html)=>n?`<details class="diffgrp" ${n<=12?'open':''}><summary><span>${title}</span><span class="badge ${color}">${n}</span></summary><div class="difflist">${html}</div></details>`:"";
  const v=x=>x==null?'<span style="color:var(--ink-faint)">未繳</span>':`<span class="num">${x}</span>`;
  return `<div class="card"><div class="card-h"><div><h2>比對結果 · ${esc(p.fileName)}</h2>
      <div class="sub">檔案 ${p.parsed.rows.length} 筆 · 對到 ${plan.matched} 人 · 未變動 ${plan.same} 個分數</div></div>
    <div class="row"><button class="btn" id="syncCancel">取消</button><button class="btn gold" id="syncApply">套用 ${plan.total} 項變更</button></div></div>
    <div class="card-b" style="display:flex;flex-direction:column;gap:10px">
      ${plan.total===0?`<div class="empty" style="padding:24px"><h3>資料已是最新 ✓</h3><p>檔案內容與目前班級完全一致,沒有需要更新的項目。</p></div>`:""}
      ${grp("新增成績項目(欄位)",plan.newItems.length,"add",`<table>${plan.newItems.map(i=>`<tr><td><b>${esc(i.name)}</b></td><td><span class="grp">${esc(i.category)}</span></td><td class="hint">新欄位 · 配分與滿分預設 0 / 100,請至成績登錄調整</td></tr>`).join("")}</table>`)}
      ${grp("新增學生",plan.newStu.length,"add",`<table>${plan.newStu.map(r=>`<tr><td class="num">${esc(r.sid)}</td><td><b>${esc(r.name)}</b></td><td>${esc(r.dept)}</td><td>${esc(r.group)}</td><td class="hint">點名 ${r.att==null?'—':r.att}</td></tr>`).join("")}</table>`)}
      ${grp("更新點名成績",plan.updAtt.length,"chg",`<table>${plan.updAtt.map(u=>`<tr><td class="num">${esc(u.acct)}</td><td>${esc(u.name)}</td><td class="r"><span class="oldv">${u.from==null?'—':u.from}</span><span class="arrow">→</span><span class="newv">${u.to==null?'—':u.to}</span></td></tr>`).join("")}</table>`)}
      ${grp("更新成績分數",plan.updGrade.length,"chg",`<table>${plan.updGrade.map(u=>`<tr><td class="num">${esc(u.acct)}</td><td>${esc(u.name)}</td><td><span class="grp">${esc(u.itemName)}</span></td><td class="r"><span class="oldv">${u.from==null?'未繳':u.from}</span><span class="arrow">→</span><span class="newv">${u.to==null?'未繳':u.to}</span></td></tr>`).join("")}</table>`)}
      ${grp("更新學生資料",plan.updStu.length,"chg",`<table>${plan.updStu.map(u=>`<tr><td class="num">${esc(u.acct)}</td><td>${esc(u.name)}</td><td class="grp">${esc({sid:'帳號',seat:'座號',name:'姓名',dept:'院系',group:'班級'}[u.field])}</td><td class="r"><span class="oldv">${esc(u.from)||'—'}</span><span class="arrow">→</span><span class="newv">${esc(u.to)}</span></td></tr>`).join("")}</table>`)}
    </div></div>`;
}

