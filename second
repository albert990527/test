function bindAll(sel,fn){ document.querySelectorAll(sel).forEach(el=>el.onclick=fn); }
function enterBlur(inp){ inp.onkeydown=e=>{ if(e.key==="Enter") inp.blur(); }; }

function fileDialog(){ const i=document.createElement("input"); i.type="file"; i.accept=".xlsx,.xls,.csv";
  i.onchange=()=>{ if(i.files[0]) handleFile(i.files[0]); }; i.click(); }
async function handleFile(file){
  const cls=C();
  try{
    const parsed=await readFile(file);
    if(!parsed.rows.length){ toast("檔案中沒有讀到學生資料"); return; }
    const plan=planSync(cls,parsed);
    const proceed=()=>{ pendingSync={fileName:file.name,parsed,plan}; view="sync"; render();
      toast(plan.total?("比對完成:"+plan.total+" 項變更"):"資料已是最新"); };
    if(cls.students.length && plan.matched===0)
      askConfirm("這個檔案的帳號和「"+cls.name+"」完全對不上,可能選錯班級了。\n仍要繼續嗎?(會全部視為新學生)",proceed,"仍要繼續");
    else proceed();
  }catch(e){ toast("讀取失敗:"+(e.message||e)); }
}

