/* ---------- 計算 ---------- */
function attendanceScore(cls,sid){ const v=cls.attDirect[sid]; return (v==null||v===""||isNaN(v))?null:clamp(+v,0,100); }
function gradeScore(cls,sid){
  const items=cls.gradeItems; if(!items.length) return null;
  const g=cls.grades[sid]||{}, zero=cls.settings.missingAsZero;
  let sum=0,wsum=0,any=false;
  items.forEach(i=>{ const v=g[i.id],w=(+i.weight||0),mx=(+i.max)||100; const has=(v!=null&&v!==""&&!isNaN(v));
    if(has){ sum+=((+v)/mx*100)*w; wsum+=w; any=true; } else if(zero){ wsum+=w; } });
  if(!any&&!zero) return null;
  return wsum? sum/wsum : (zero?0:null);
}
function bonusOf(cls,sid){ return (cls.perfLog||[]).filter(e=>e.studentId===sid).reduce((a,e)=>a+(+e.bonus||0),0); }
function compute(cls,sid){
  const w=cls.settings.weights;
  const a=attendanceScore(cls,sid), g=gradeScore(cls,sid), bonus=bonusOf(cls,sid);
  const av=a??0, gv=g??0;
  const final=clamp(av*w.attendance/100 + gv*w.grade/100 + bonus, 0, 100);
  return {a,g,bonus,final,contrib:{att:av*w.attendance/100, grd:gv*w.grade/100}};
}
function weightTotal(cls){ const w=cls.settings.weights; return (+w.attendance||0)+(+w.grade||0); }
function classAttRate(cls){ const a=cls.students.map(s=>attendanceScore(cls,s.id)).filter(v=>v!=null); return a.length?a.reduce((x,y)=>x+y,0)/a.length:null; }

/* 問題診斷 */
function diagnose(cls,sid){
  const out=[]; const a=attendanceScore(cls,sid);
  if(a!=null && a<60) out.push("點名太少");
  const g=cls.grades[sid]||{};
  const miss=i=>{ const v=g[i.id]; return v==null||v===""||isNaN(v); };
  const ex=cls.gradeItems.filter(i=>i.category==="考試"&&miss(i)).length;
  const hw=cls.gradeItems.filter(i=>i.category==="作業"&&miss(i)).length;
  if(ex) out.push("考試缺考×"+ex);
  if(hw) out.push("作業未交×"+hw);
  const gs=gradeScore(cls,sid);
  if(gs!=null && gs<cls.settings.passLine) out.push("成績偏低");
  return out;
}
function probTags(cls,sid){ const d=diagnose(cls,sid);
  return d.length? d.map(t=>`<span class="badge bad" style="margin:1px 2px">${esc(t)}</span>`).join("") : '<span style="color:var(--ink-faint)">—</span>'; }

/* ---------- 檔案解析(平台格式 xlsx / csv) ---------- */
function parseGrid(rows){
  // 找表頭列:某列含「帳號」或「姓名」
  let h=-1;
  for(let i=0;i<Math.min(rows.length,30);i++){ const row=(rows[i]||[]).map(x=>String(x==null?"":x).trim());
    if(row.includes("帳號")||row.includes("姓名")){ h=i; break; } }
  if(h<0) throw new Error("找不到表頭(需有「帳號」或「姓名」欄)");
  const hdr=rows[h].map(x=>String(x==null?"":x));
  const findCol=re=>hdr.findIndex(x=>re.test(x));
  const col={ sid:findCol(/帳號/), seat:findCol(/座號/), name:findCol(/姓名/), dept:findCol(/院系/), group:findCol(/班級/) };
  if(col.sid<0 && col.name<0) throw new Error("表頭需要有「帳號」或「姓名」欄");
  const attCol=findCol(/點名/);   // 可省略,-1 表示沒有點名欄
  // 身分/尾欄範圍
  const idIdx=[col.sid,col.seat,col.name,col.dept,col.group].filter(i=>i>=0);
  const maxId=idIdx.length?Math.max(...idIdx):0;
  let endCol=hdr.length;
  [/原始成績/,/最終成績/,/備註/,/退選/].forEach(re=>{ const i=findCol(re); if(i>maxId && i<endCol) endCol=i; });
  // 第二層表頭(合併群組下的細項名)
  const next=rows[h+1]||[];
  const anchor = col.sid>=0?col.sid:(col.name>=0?col.name:0);
  const av=String((next[anchor]==null?"":next[anchor])).trim();
  const nextIsData = col.sid>=0 ? (av!=="" && /\d/.test(av)) : (av!=="");
  const idSet=new Set(idIdx);
  const itemCols=[];
  for(let c=maxId+1;c<endCol;c++){
    if(c===attCol||idSet.has(c)) continue;
    let nm = (!nextIsData && next[c]!=null && String(next[c]).trim()!=="") ? next[c] : hdr[c];
    nm=cleanName(nm);
    if(nm) itemCols.push({col:c,name:nm});
  }
  const start = nextIsData ? h+1 : h+2;
  const num=v=>{ if(v==null||v===""||String(v).trim()==="未繳") return null; const n=Number(v); return isNaN(n)?null:n; };
  const cell=(r,i)=> (i>=0 && r[i]!=null) ? String(r[i]).trim() : "";
  const out=[];
  for(let i=start;i<rows.length;i++){
    const r=rows[i]||[];
    const sid=cell(r,col.sid), name=cell(r,col.name);
    if(sid==="" && name==="") continue;
    if(/教師|合計|平均|總計/.test(sid+name)) continue;
    out.push({ sid, seat:cell(r,col.seat), name, dept:cell(r,col.dept), group:cell(r,col.group),
      att: attCol>=0?num(r[attCol]):null, scores:itemCols.map(ic=>num(r[ic.col])) });
  }
  return { items:itemCols.map(x=>x.name), hasAtt:attCol>=0, rows:out };
}
function parseCSVText(text){
  const rows=[]; let cur=[],val="",q=false;
  for(let i=0;i<text.length;i++){ const ch=text[i];
    if(q){ if(ch==='"'){ if(text[i+1]==='"'){ val+='"'; i++; } else q=false; } else val+=ch; }
    else if(ch==='"') q=true;
    else if(ch===","){ cur.push(val); val=""; }
    else if(ch==="\n"){ cur.push(val); rows.push(cur); cur=[]; val=""; }
    else if(ch!=="\r") val+=ch; }
  if(val!==""||cur.length){ cur.push(val); rows.push(cur); }
  return rows;
}
function readFile(file){
  return new Promise((res,rej)=>{
    const r=new FileReader();
    r.onerror=()=>rej(new Error("讀取檔案失敗"));
    if(/\.csv$/i.test(file.name)){
      r.onload=()=>{ try{ res(parseGrid(parseCSVText(String(r.result).replace(/^\ufeff/,"")))); }catch(e){ rej(e); } };
      r.readAsText(file,"utf-8");
    } else {
      r.onload=()=>{ try{
        if(!window.XLSX) throw new Error("Excel 解析元件未載入(需連上網路),請改上傳 CSV");
        const wb=XLSX.read(new Uint8Array(r.result),{type:"array"});
        const ws=wb.Sheets[wb.SheetNames.includes("匯總")?"匯總":wb.SheetNames[0]];
        res(parseGrid(XLSX.utils.sheet_to_json(ws,{header:1,raw:true,defval:null})));
      }catch(e){ rej(e); } };
      r.readAsArrayBuffer(file);
    }
  });
}

/* ---------- 同步比對 ---------- */
function planSync(cls,parsed){
  const plan={newItems:[],newStu:[],updStu:[],updAtt:[],updGrade:[],matched:0,same:0};
  // 欄位(成績項目):名稱已存在→沿用;不存在→新增
  const byName={}; cls.gradeItems.forEach(i=>byName[i.name]=i);
  parsed.items.forEach(nm=>{ if(!byName[nm]){ const it={id:uid(),name:nm,category:/作業/.test(nm)?"作業":"考試",weight:0,max:100,_new:true};
    byName[nm]=it; plan.newItems.push(it); } });
  const used=new Set();
  const norm=v=>String(v==null?"":v).trim();
  const matchStu=r=>{
    const rs=norm(r.sid), rn=norm(r.name), rk=norm(r.seat);
    // 對每位既有學生計算「帳號/姓名/座號」吻合數,任兩項吻合即視為同一人
    let best=null, bestScore=0, tie=false;
    cls.students.forEach(x=>{
      if(used.has(x.id)) return;
      let sc=0;
      if(rs && norm(x.sid)===rs) sc++;
      if(rn && norm(x.name)===rn) sc++;
      if(rk && norm(x.seat)===rk) sc++;
      if(sc>bestScore){ bestScore=sc; best=x; tie=false; } else if(sc===bestScore && sc>0) tie=true;
    });
    if(bestScore>=2 && !(tie&&bestScore<2)) return best;      // 任兩項吻合
    // 後備:帳號完全相同且在既有名單唯一(帳號通常是唯一鍵)
    if(rs){ const cand=cls.students.filter(x=>norm(x.sid)===rs && !used.has(x.id)); if(cand.length===1) return cand[0]; }
    return null;
  };
  parsed.rows.forEach(r=>{
    const s=matchStu(r);
    if(!s){ plan.newStu.push(r); return; }
    used.add(s.id); plan.matched++;
    // 帳號視為可更新欄位(以姓名對齊時,帳號若不同會被更新/補上)
    ["sid","seat","name","dept","group"].forEach(f=>{ const ov=String(s[f]||""), nv=String(r[f]||"");
      if(nv!=="" && ov!==nv) plan.updStu.push({sid:s.id,acct:s.sid,name:s.name,field:f,from:ov,to:nv}); });
    if(parsed.hasAtt){   // 檔案沒有點名欄時,完全不動點名成績
      const oa=cls.attDirect[s.id];
      const sameAtt=(oa==null&&r.att==null)||(oa!=null&&r.att!=null&&Number(oa)===Number(r.att));
      if(!sameAtt) plan.updAtt.push({sid:s.id,acct:s.sid,name:s.name,from:oa,to:r.att});
    }
    parsed.items.forEach((nm,ix)=>{ const it=byName[nm]; const nv=r.scores[ix];
      const ov=it._new?undefined:(cls.grades[s.id]||{})[it.id];
      const oNull=(ov==null||ov===""||isNaN(ov)), nNull=(nv==null);
      if(oNull&&nNull) return;
      if(!oNull&&!nNull&&Number(ov)===Number(nv)){ plan.same++; return; }
      plan.updGrade.push({sid:s.id,acct:s.sid,name:s.name,item:it,itemName:nm,from:oNull?null:ov,to:nv}); });
  });
  plan.total=plan.newItems.length+plan.newStu.length+plan.updStu.length+plan.updAtt.length+plan.updGrade.length;
  return plan;
}
function applySync(cls,plan,parsed){
  plan.newItems.forEach(it=>{ const c={id:it.id,name:it.name,category:it.category,weight:it.weight,max:it.max}; cls.gradeItems.push(c); });
  plan.newStu.forEach(r=>{ const id=uid();
    cls.students.push({id,sid:r.sid,seat:r.seat,name:r.name,dept:r.dept,group:r.group});
    if(r.att!=null) cls.attDirect[id]=r.att;
    cls.grades[id]={};
    const byName={}; cls.gradeItems.forEach(i=>byName[i.name]=i);
    parsed.items.forEach((nm,ix)=>{ const it=byName[nm]; const v=r.scores[ix]; if(it&&v!=null) cls.grades[id][it.id]=v; }); });
  plan.updStu.forEach(u=>{ const s=cls.students.find(x=>x.id===u.sid); if(s) s[u.field]=u.to; });
  plan.updAtt.forEach(u=>{ if(u.to==null) delete cls.attDirect[u.sid]; else cls.attDirect[u.sid]=u.to; });
  plan.updGrade.forEach(u=>{ cls.grades[u.sid]=cls.grades[u.sid]||{};
    if(u.to==null) delete cls.grades[u.sid][u.item.id]; else cls.grades[u.sid][u.item.id]=u.to; });
  save();
}

