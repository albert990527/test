}
/* 彩帶(canvas,自繪) */
function confetti(){
  const c=document.createElement("canvas"); c.style.cssText="position:fixed;inset:0;pointer-events:none;z-index:200";
  c.width=window.innerWidth; c.height=window.innerHeight; document.body.appendChild(c); const ctx=c.getContext("2d");
  const cols=["#B0812B","#2E7D74","#2B4A80","#C07A0C","#177C46","#B32633"], P=[];
  for(let i=0;i<130;i++) P.push({x:c.width/2+(Math.random()-.5)*160,y:c.height*0.30,vx:(Math.random()-.5)*11,vy:Math.random()*-10-3,s:5+Math.random()*7,col:cols[i%cols.length],rot:Math.random()*6,vr:(Math.random()-.5)*.5});
  let t0=null;
  const frame=ts=>{ if(!t0)t0=ts; const dt=ts-t0; ctx.clearRect(0,0,c.width,c.height);
    P.forEach(p=>{ p.vy+=0.3; p.x+=p.vx; p.y+=p.vy; p.rot+=p.vr; ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot);
      ctx.globalAlpha=Math.max(0,1-dt/1700); ctx.fillStyle=p.col; ctx.fillRect(-p.s/2,-p.s/2,p.s,p.s*0.62); ctx.restore(); });
    if(dt<1700) requestAnimationFrame(frame); else c.remove(); };
  requestAnimationFrame(frame);
}
/* 數字跳動 */
function countUp(){
  document.querySelectorAll("[data-count]").forEach(el=>{
    const to=parseFloat(el.dataset.count); if(isNaN(to)) return;
    const dec=parseInt(el.dataset.dec||"0"), suf=el.dataset.suf||""; let t0=null;
    const f=ts=>{ if(!t0)t0=ts; const k=Math.min(1,(ts-t0)/600); const e=1-Math.pow(1-k,3);
      el.textContent=(to*e).toFixed(dec)+suf; if(k<1) requestAnimationFrame(f); else el.textContent=to.toFixed(dec)+suf; };
    requestAnimationFrame(f);
  });
}

