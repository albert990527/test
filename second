function weightedPick(cls){
  const st=cls.students;
  if(!pickCold) return st[Math.floor(Math.random()*st.length)];
  const picks={}; (cls.pickLog||[]).forEach(id=>picks[id]=(picks[id]||0)+1);
  const w=st.map(s=>1/(1+(picks[s.id]||0))/(1+bonusOf(cls,s.id)*0.3));
  let sum=w.reduce((a,b)=>a+b,0), r=Math.random()*sum;
  for(let i=0;i<st.length;i++){ r-=w[i]; if(r<=0) return st[i]; }
  return st[st.length-1];
}
function runPick(){
  const cls=C(), st=cls.students; if(pickSpin||!st.length) return;
  pickSpin=true;
  const nameEl=document.getElementById("pickName"), metaEl=document.getElementById("pickMeta"),
        btn=document.getElementById("pickBtn"), stage=document.querySelector(".pickstage");
  if(stage) stage.classList.add("pickspin"); if(btn){ btn.disabled=true; btn.textContent="…"; }
  const winner=weightedPick(cls);
  const delays=[]; let d=45; for(let i=0;i<26;i++){ delays.push(Math.min(d,300)); d=d*1.14+3; }
  let i=0;
  const tick=()=>{
    if(i<delays.length){ const rnd=st[Math.floor(Math.random()*st.length)];
      if(nameEl) nameEl.textContent=rnd.name; if(metaEl) metaEl.textContent=rnd.sid||'';
      setTimeout(tick,delays[i]); i++;
    } else { pickResult=winner; pickSpin=false; cls.pickLog.push(winner.id); save(); confetti(); render(); }
  };
  tick();
}
