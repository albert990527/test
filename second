/* ---------- 匯出/匯入 ---------- */
function download(name,text,type="text/plain"){ const b=new Blob(["\ufeff"+text],{type}),u=URL.createObjectURL(b);
  const a=document.createElement("a"); a.href=u; a.download=name; a.click(); URL.revokeObjectURL(u); }
function exportCSV(){ const cls=C(), items=cls.gradeItems;
  const hdr=["帳號","座號","姓名","院系","班級","點名成績",...items.map(i=>i.name+"(/"+((+i.max)||100)+")"),"加權成績","加分","混合成績","狀態","問題"];
  const lines=[hdr.join(",")];
  cls.students.forEach(s=>{ const c=compute(cls,s.id), g=cls.grades[s.id]||{};
    const row=[s.sid,s.seat,s.name,s.dept,s.group,c.a==null?"":c.a,...items.map(i=>g[i.id]??"未繳"),fmt(c.g),c.bonus,fmt(c.final),
      c.final>=cls.settings.passLine?"及格":"不及格", diagnose(cls,s.id).join(" / ")];
    lines.push(row.map(x=>`"${String(x??"").replace(/"/g,'""')}"`).join(",")); });
  download(cls.name+"_混合成績_"+todayISO()+".csv",lines.join("\n"),"text/csv"); toast("已匯出 CSV"); }
function exportJSON(){ download("成績系統備份_"+todayISO()+".json",JSON.stringify(S,null,1),"application/json"); toast("已匯出備份"); }
function importJSON(){ const inp=document.createElement("input"); inp.type="file"; inp.accept=".json,application/json";
  inp.onchange=()=>{ const f=inp.files[0]; if(!f) return; const r=new FileReader();
    r.onload=()=>{ try{ const d=JSON.parse(r.result); if(!d.classes||!Array.isArray(d.classes)) throw 0;
      askConfirm("匯入將覆蓋目前所有班級,確定?",()=>{ S=migrate(d); if(!S.activeClass&&S.classes.length) S.activeClass=S.classes[0].id;
        save(); view="dash"; render(); toast("已匯入 "+S.classes.length+" 個班級"); },"覆蓋匯入",true);
    }catch(e){ toast("檔案格式不正確"); } }; r.readAsText(f); }; inp.click(); }

/* ---------- Toast ---------- */
let toastTimer;
function toast(msg){ let t=document.querySelector(".toast"); if(!t){ t=document.createElement("div"); t.className="toast"; document.body.appendChild(t); }
  t.textContent=msg; requestAnimationFrame(()=>t.classList.add("show")); clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove("show"),2400); }

(async function init(){ await loadState(); render(); })();
if('serviceWorker' in navigator && location.protocol.indexOf('http')===0){ navigator.serviceWorker.register('service-worker.js').catch(()=>{}); }
</script>
