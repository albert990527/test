function modal(title,html,onSave,saveLabel="儲存"){
  const ov=document.createElement("div"); ov.className="ov";
  ov.innerHTML=`<div class="modal"><div class="modal-h">${esc(title)}<button class="x">×</button></div><div class="modal-b">${html}</div>
    <div class="modal-f"><button class="btn" data-cancel>取消</button><button class="btn pri" data-ok>${esc(saveLabel)}</button></div></div>`;
  document.body.appendChild(ov); const close=()=>ov.remove();
  ov.querySelector(".x").onclick=close; ov.querySelector("[data-cancel]").onclick=close; ov.onclick=e=>{ if(e.target===ov) close(); };
  ov.querySelector("[data-ok]").onclick=()=>{ if(onSave(ov)!==false) close(); };
  const f=ov.querySelector("input,textarea,select"); if(f) f.focus(); return ov;
}
function askConfirm(msg,onYes,yesLabel="確定",danger=false){
  const ov=document.createElement("div"); ov.className="ov";
  ov.innerHTML=`<div class="modal" style="max-width:420px"><div class="modal-h">請確認<button class="x">×</button></div>
    <div class="modal-b"><p style="margin:0;line-height:1.7;white-space:pre-line">${esc(msg)}</p></div>
    <div class="modal-f"><button class="btn" data-no>取消</button><button class="btn ${danger?'danger':'pri'}" data-yes>${esc(yesLabel)}</button></div></div>`;
  document.body.appendChild(ov); const close=()=>ov.remove();
  ov.querySelector(".x").onclick=close; ov.querySelector("[data-no]").onclick=close; ov.onclick=e=>{ if(e.target===ov) close(); };
  ov.querySelector("[data-yes]").onclick=()=>{ close(); onYes(); };
}
