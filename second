/* 成績分布圖 */
function distCard(cls){
  const st=cls.students, bins=new Array(10).fill(0);
  st.forEach(s=>{ let b=Math.floor(compute(cls,s.id).final/10); if(b>9)b=9; if(b<0)b=0; bins[b]++; });
  const max=Math.max(1,...bins), pass=cls.settings.passLine;
  const label=i=> i===9?'90–100':(i*10)+'–'+(i*10+9);
  return `<div class="card"><div class="card-h"><div><h2>成績分布</h2><div class="sub">各分數區間人數;紅色為未達及格線 ${pass}</div></div></div>
