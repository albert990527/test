<!-- 助教課學生成績點名績效混合系統 · v3 -->
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="theme-color" content="#17213B">
<link rel="manifest" href="manifest.webmanifest">
<link rel="icon" href="icons/icon-192.png">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="助教成績">
<meta name="mobile-web-app-capable" content="yes">
<title>助教課成績系統</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  :root{
    --paper:#EBEEF3; --surface:#FFFFFF; --surface-2:#F6F8FB;
    --side-bg:#17213B;
    --ink:#17213B; --ink-soft:#5A647E; --ink-faint:#8B93A7;
    --line:#DBE0EA; --line-strong:#C3CAD8;
    --gold:#B0812B; --gold-dk:#8F6820;
    --att:#2E7D74; --grd:#2B4A80;
    --ok:#177C46; --warn:#C07A0C; --bad:#B32633;
    --add:#177C46; --chg:#C07A0C;
    --font:"PingFang TC","Microsoft JhengHei","Noto Sans TC",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
    --mono:"SF Mono","JetBrains Mono",ui-monospace,Menlo,Consolas,"Courier New",monospace;
    --sh:0 1px 2px rgba(23,33,59,.06),0 4px 14px rgba(23,33,59,.05);
  }
  *{box-sizing:border-box} html,body{margin:0}
  body.dark{
    --paper:#0F131C; --surface:#1A2130; --surface-2:#222B3C;
    --ink:#E9EDF5; --ink-soft:#A6B0C6; --ink-faint:#727E97;
    --line:#2C3546; --line-strong:#3A4558;
    --gold:#D0A24A; --gold-dk:#B98A34;
    --sh:0 1px 2px rgba(0,0,0,.35),0 4px 16px rgba(0,0,0,.35);
  }
  body{background:var(--paper);color:var(--ink);font-family:var(--font);font-size:14px;line-height:1.5;-webkit-font-smoothing:antialiased}
  .num{font-family:var(--mono);font-variant-numeric:tabular-nums;font-feature-settings:"tnum"}
  button{font-family:inherit;cursor:pointer}
  input,select,textarea{font-family:inherit;font-size:14px;color:var(--ink)}
  ::-webkit-scrollbar{height:10px;width:10px}::-webkit-scrollbar-thumb{background:var(--line-strong);border-radius:6px}

  .app{display:grid;grid-template-columns:230px 1fr;min-height:100vh}
  .side{background:var(--ink);color:#C9D0E0;padding:20px 14px;position:sticky;top:0;height:100vh;display:flex;flex-direction:column;gap:4px}
  .brand{display:flex;align-items:baseline;gap:8px;padding:6px 10px 16px;border-bottom:1px solid rgba(255,255,255,.09);margin-bottom:10px}
  .brand .seal{font-family:var(--mono);font-weight:700;letter-spacing:1px;color:var(--gold);border:1.5px solid var(--gold);border-radius:5px;padding:2px 6px;font-size:12px}
  .brand b{color:#fff;font-size:15px;letter-spacing:.5px}
  .brand small{display:block;color:#7F89A3;font-size:11px;margin-top:2px;letter-spacing:2px}
  .nav{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px}
  .nav button{width:100%;text-align:left;background:none;border:0;color:#C0C8DA;padding:9px 12px;border-radius:7px;font-size:14px;display:flex;align-items:center;gap:10px;transition:.12s}
  .nav button .ico{width:18px;text-align:center;opacity:.85}
  .nav button:hover{background:rgba(255,255,255,.06);color:#fff}
  .nav button.on{background:rgba(176,129,43,.16);color:#fff;box-shadow:inset 2px 0 0 var(--gold)}
  .side-foot{margin-top:auto;font-size:11px;color:#6C7691;padding:10px;border-top:1px solid rgba(255,255,255,.08);line-height:1.6}

  main{padding:22px 30px 60px;max-width:1180px}
  .topbar{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:18px;flex-wrap:wrap}
  .clswitch{display:flex;align-items:center;gap:8px}
  .clswitch label{font-size:12px;color:var(--ink-soft);font-weight:600}
  .clswitch select{border:1px solid var(--line-strong);border-radius:9px;padding:8px 12px;background:var(--surface);font-weight:600;box-shadow:var(--sh);min-width:210px}
  .clswitch select:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(176,129,43,.14)}
  .head{display:flex;justify-content:space-between;align-items:flex-end;gap:16px;margin-bottom:18px;flex-wrap:wrap}
  .head h1{margin:0;font-size:22px;letter-spacing:.5px}
  .head p{margin:4px 0 0;color:var(--ink-soft);font-size:13px}

  .card{background:var(--surface);border:1px solid var(--line);border-radius:12px;box-shadow:var(--sh);margin-bottom:18px}
  .card-h{padding:14px 18px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
  .card-h h2{margin:0;font-size:15px;letter-spacing:.5px}
  .card-h .sub{color:var(--ink-faint);font-size:12px;margin-top:2px}
  .card-b{padding:16px 18px}.card-b.flush{padding:0}

  .btn{border:1px solid var(--line-strong);background:var(--surface);color:var(--ink);padding:7px 13px;border-radius:8px;font-size:13px;font-weight:500;transition:.12s;display:inline-flex;align-items:center;gap:6px}
  .btn:hover{border-color:var(--ink-soft);background:var(--surface-2)}
  .btn.pri{background:var(--ink);color:#fff;border-color:var(--ink)}.btn.pri:hover{background:#0f1830}
  .btn.gold{background:var(--gold);border-color:var(--gold);color:#fff}.btn.gold:hover{background:var(--gold-dk)}
  .btn.sm{padding:4px 9px;font-size:12px}
  .btn.danger{color:var(--bad);border-color:#E8B9BE}.btn.danger:hover{background:#FCEEEF;border-color:var(--bad)}
  .btn.ghost{border-color:transparent;background:transparent;color:var(--ink-soft)}.btn.ghost:hover{background:var(--surface-2);color:var(--ink)}

  .tbl{width:100%;border-collapse:collapse;font-size:13.5px}
  .tbl th,.tbl td{padding:9px 12px;text-align:left;border-bottom:1px solid var(--line)}
  .tbl thead th{background:var(--surface-2);color:var(--ink-soft);font-weight:600;font-size:12px;letter-spacing:.4px;position:sticky;top:0;z-index:2;white-space:nowrap}
  .tbl tbody tr:hover{background:#FAFBFD}
  .tbl td.c,.tbl th.c{text-align:center}.tbl td.r,.tbl th.r{text-align:right}
  .tbl .sid{color:var(--ink-faint);font-family:var(--mono);font-size:12.5px}
  .scroll{overflow:auto;max-height:70vh;border-radius:0 0 12px 12px}
  .grp{display:inline-block;font-size:11px;background:var(--surface-2);border:1px solid var(--line);color:var(--ink-soft);padding:1px 7px;border-radius:20px}

  .cell-in{width:60px;border:1px solid var(--line);border-radius:6px;padding:5px 6px;text-align:center;font-family:var(--mono);background:var(--surface-2)}
  .cell-in:focus{outline:none;border-color:var(--gold);background:#fff;box-shadow:0 0 0 3px rgba(176,129,43,.14)}
  .cell-in.big{width:72px}
  input.f,select.f,textarea.f{width:100%;border:1px solid var(--line-strong);border-radius:8px;padding:8px 10px;background:var(--surface)}
  input.f:focus,select.f:focus,textarea.f:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(176,129,43,.14)}
  label.fl{display:block;font-size:12px;color:var(--ink-soft);margin:0 0 5px;font-weight:600;letter-spacing:.3px}

  .final{font-family:var(--mono);font-size:16px;font-weight:700}
  .badge{font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;letter-spacing:.5px;display:inline-block}
  .badge.ok{background:#E4F2EA;color:var(--ok)}.badge.warn{background:#FBF0DD;color:#9A6205}.badge.bad{background:#FBE6E8;color:var(--bad)}
  .badge.add{background:#E4F2EA;color:var(--add)}.badge.chg{background:#FBF0DD;color:var(--chg)}

  .compbar{display:flex;height:12px;border-radius:6px;overflow:hidden;background:var(--surface-2);min-width:120px;border:1px solid var(--line)}
  .compbar i{display:block;height:100%}
  .comp-att{background:var(--att)}.comp-grd{background:var(--grd)}

  .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:18px}
  .stat{background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:16px 18px;box-shadow:var(--sh)}
  .stat .k{font-size:12px;color:var(--ink-soft);letter-spacing:.5px}
  .stat .v{font-family:var(--mono);font-size:30px;font-weight:700;line-height:1.1;margin-top:6px}
  .stat .v small{font-size:14px;color:var(--ink-faint);font-weight:400}
  .stat .m{font-size:11.5px;color:var(--ink-faint);margin-top:4px}

  .legend{display:flex;gap:16px;flex-wrap:wrap;font-size:12px;color:var(--ink-soft);align-items:center}
  .legend span{display:inline-flex;align-items:center;gap:6px}.legend i{width:11px;height:11px;border-radius:3px;display:inline-block}
  .empty{text-align:center;padding:44px 20px;color:var(--ink-faint)}
  .empty h3{color:var(--ink);margin:0 0 6px;font-size:16px}
  .empty p{margin:0 auto 18px;max-width:460px;font-size:13.5px;line-height:1.6}
  .row{display:flex;gap:12px;flex-wrap:wrap}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}

  .ov{position:fixed;inset:0;background:rgba(15,22,42,.5);display:flex;align-items:center;justify-content:center;padding:20px;z-index:50}
  .modal{background:var(--surface);border-radius:14px;max-width:560px;width:100%;box-shadow:0 20px 60px rgba(15,22,42,.3);max-height:88vh;overflow:auto}
  .modal.wide{max-width:760px}
  .modal-h{padding:16px 20px;border-bottom:1px solid var(--line);font-weight:700;font-size:15px;display:flex;justify-content:space-between;align-items:center}
  .modal-b{padding:18px 20px;display:flex;flex-direction:column;gap:14px}
  .modal-f{padding:14px 20px;border-top:1px solid var(--line);display:flex;justify-content:flex-end;gap:8px}
  .x{border:0;background:none;font-size:20px;color:var(--ink-faint);line-height:1;padding:2px 6px;border-radius:6px}.x:hover{background:var(--surface-2);color:var(--ink)}

  .toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:var(--ink);color:#fff;padding:11px 20px;border-radius:10px;font-size:13.5px;box-shadow:0 8px 24px rgba(0,0,0,.25);z-index:80;opacity:0;transition:.25s;pointer-events:none}
  .toast.show{opacity:1;bottom:30px}
  .hint{font-size:12px;color:var(--ink-faint);line-height:1.6}
  .tabs{display:flex;gap:4px;background:var(--surface-2);padding:4px;border-radius:10px;flex-wrap:wrap}
  .tabs button{border:0;background:none;padding:6px 12px;border-radius:7px;font-size:13px;color:var(--ink-soft)}
  .tabs button.on{background:var(--surface);color:var(--ink);box-shadow:var(--sh);font-weight:600}
  .wt-warn{color:var(--bad);font-weight:600}.mono-tot{font-family:var(--mono);color:var(--ink-soft)}

  /* 課堂抽籤 */
  .pickstage{background:linear-gradient(160deg,#1B2742,#2A3A5E);border-radius:16px;padding:38px 22px;text-align:center;color:#fff;box-shadow:inset 0 2px 20px rgba(0,0,0,.25);position:relative;overflow:hidden}
  .pickstage::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(176,129,43,.28),transparent 60%);pointer-events:none}
  .pickstage .lbl{font-size:12px;letter-spacing:3px;color:#9FB0D0;text-transform:uppercase}
  .pickname{font-size:52px;font-weight:800;letter-spacing:2px;margin:8px 0 4px;line-height:1.1;min-height:60px;transition:transform .1s}
  .pickname.pop{animation:pop .5s cubic-bezier(.2,1.4,.4,1)}
  @keyframes pop{0%{transform:scale(.7);opacity:.5}60%{transform:scale(1.12)}100%{transform:scale(1)}}
  .pickmeta{font-family:var(--mono);color:#C9D4EA;font-size:14px;min-height:20px}
  .pickspin .pickname{color:var(--gold);opacity:.92}
  .spinbtn{font-size:20px;font-weight:800;padding:14px 46px;border-radius:14px;letter-spacing:4px;margin-top:22px}
  .spinbtn:disabled{opacity:.6;cursor:default}
  .pickchip{display:inline-flex;align-items:center;gap:5px;font-size:12px;background:var(--surface-2);border:1px solid var(--line);border-radius:20px;padding:3px 10px;margin:3px}
  .pickchip.cur{background:#FBF6EA;border-color:var(--gold);color:var(--gold-dk);font-weight:700}

  /* 成績分布 */
  .distrow{display:grid;grid-template-columns:78px 1fr 44px;align-items:center;gap:12px;margin:9px 0}
  .distrow .dl{font-size:12.5px;color:var(--ink-soft);text-align:right}
  .distrow .dc{font-family:var(--mono);font-weight:700;text-align:right}
  .distbar{height:22px;background:var(--surface-2);border-radius:6px;overflow:hidden;border:1px solid var(--line)}
  .distbar>i{display:block;height:100%;width:0;border-radius:6px 0 0 6px;transition:width .9s cubic-bezier(.22,1,.36,1)}

  /* 榮譽榜 */
  .honor{display:flex;gap:12px;flex-wrap:wrap}
  .medal{flex:1;min-width:150px;border:1px solid var(--line);border-radius:12px;padding:12px 14px;display:flex;align-items:center;gap:12px;background:var(--surface-2)}
  .medal .ic{font-size:28px}
  .medal .nm{font-weight:700}.medal .sc{font-family:var(--mono);color:var(--ink-soft);font-size:12.5px}
  .medal.g1{background:linear-gradient(135deg,#FBF3DE,#F5E7C0);border-color:#E7CE92}
  .medal.g2{background:linear-gradient(135deg,#F1F3F6,#E4E8EE);border-color:#D3D9E2}
  .medal.g3{background:linear-gradient(135deg,#F6EDE4,#EBDccb);border-color:#DEC6AC}

  /* 彩帶 */
  .confetti{position:fixed;inset:0;pointer-events:none;z-index:90;overflow:hidden}
  .confetti i{position:absolute;top:-14px;width:9px;height:14px;border-radius:2px;animation:fall linear forwards}
  @keyframes fall{to{transform:translateY(104vh) rotate(640deg);opacity:.9}}

  .loader{display:flex;align-items:center;justify-content:center;height:100vh;color:var(--ink-soft);gap:10px;font-size:14px}
  .spin{width:18px;height:18px;border:2.5px solid var(--line);border-top-color:var(--gold);border-radius:50%;animation:sp .8s linear infinite}
  @keyframes sp{to{transform:rotate(360deg)}}

  /* sync diff */
  .diffgrp{border:1px solid var(--line);border-radius:10px;overflow:hidden}
  .diffgrp>summary{padding:10px 14px;background:var(--surface-2);cursor:pointer;font-weight:600;font-size:13px;display:flex;justify-content:space-between;align-items:center}
  .diffgrp>summary::-webkit-details-marker{display:none}
  .difflist{max-height:210px;overflow:auto}
  .difflist table{width:100%;border-collapse:collapse;font-size:12.5px}
  .difflist td{padding:6px 12px;border-bottom:1px solid var(--line)}
  .arrow{color:var(--ink-faint);margin:0 6px}
  .oldv{color:var(--ink-faint);text-decoration:line-through}
  .newv{color:var(--chg);font-weight:700}
  .drop{border:2px dashed var(--line-strong);border-radius:12px;padding:26px;text-align:center;color:var(--ink-soft);background:var(--surface-2)}
  .drop.hot{border-color:var(--gold);background:#FBF6EA}

  @media(max-width:860px){
    .app{grid-template-columns:1fr}
    .side{position:static;height:auto}.nav{flex-direction:row;overflow-x:auto}.nav button{white-space:nowrap}.side-foot{display:none}
    main{padding:16px 14px 50px}.grid2{grid-template-columns:1fr}
  }

  /* 主題色固定的側欄,深色模式不受 --ink 反轉影響 */
  .side{background:var(--side-bg)}
  .theme-btn{border:1px solid var(--line-strong);background:var(--surface);color:var(--ink);width:36px;height:36px;border-radius:9px;font-size:16px;display:inline-flex;align-items:center;justify-content:center;box-shadow:var(--sh)}
  .theme-btn:hover{border-color:var(--gold)}

  /* 分組 */
  .grp-card{border:1px solid var(--line);border-radius:12px;overflow:hidden;background:var(--surface);animation:rise .4s ease both}
  @keyframes rise{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
  .grp-h{padding:9px 12px;background:var(--ink);color:#fff;font-weight:700;font-size:13px;display:flex;justify-content:space-between;align-items:center}
  body.dark .grp-h{background:#0c1220}
  .grp-h .grp{background:rgba(255,255,255,.15);border:0;color:#fff}
  .grp-list{margin:0;padding:8px 12px 10px 30px;display:flex;flex-direction:column;gap:3px}
  .grp-list li{font-size:13.5px}.grp-list li .sid{color:var(--ink-faint);margin-left:6px;font-size:11px}
  .toolbar-int{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
</style>

<div id="root"><div class="loader"><div class="spin"></div>載入資料中…</div></div>

<script>
"use strict";

if(!(window.storage && typeof window.storage.get==="function")){
  window.storage={
    async get(k){ try{ const v=localStorage.getItem(k); return v==null?null:{key:k,value:v}; }catch(e){ return null; } },
    async set(k,v){ try{ localStorage.setItem(k,String(v)); }catch(e){} return {key:k,value:v}; },
    async delete(k){ try{ localStorage.removeItem(k); }catch(e){} return {key:k,deleted:true}; },
    async list(prefix){ const keys=[]; try{ for(let i=0;i<localStorage.length;i++){ const kk=localStorage.key(i); if(!prefix||String(kk).indexOf(prefix)===0) keys.push(kk); } }catch(e){} return {keys}; }
  };
}
